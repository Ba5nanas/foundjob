FOUNDJOB_DOMAIN=foundjob.net
NODE_ENV=development

POSTGRES_USER=foundjob
POSTGRES_PASSWORD=foundjob_dev_password
POSTGRES_DB=foundjob
POSTGRES_HOST=foundjob-postgres
POSTGRES_PORT=5432

MONGODB_URI=mongodb://foundjob-mongodb:27017/foundjob_files
REDIS_URL=redis://foundjob-redis:6379
KAFKA_BROKERS=foundjob-kafka:9092

MAIN_CONTROL_SOCKET=/var/run/foundjob/main-control.sock
AUTH_SERVICE_SOCKET=/var/run/foundjob/auth-service.sock
USER_SERVICE_SOCKET=/var/run/foundjob/user-service.sock
COMPANY_SERVICE_SOCKET=/var/run/foundjob/company-service.sock
JOB_SERVICE_SOCKET=/var/run/foundjob/job-service.sock
APPLICATION_SERVICE_SOCKET=/var/run/foundjob/application-service.sock
RESUME_SERVICE_SOCKET=/var/run/foundjob/resume-service.sock
APPOINTMENT_SERVICE_SOCKET=/var/run/foundjob/appointment-service.sock
PACKAGE_SERVICE_SOCKET=/var/run/foundjob/package-service.sock
BACKOFFICE_SERVICE_SOCKET=/var/run/foundjob/backoffice-service.sock
FILE_SERVICE_SOCKET=/var/run/foundjob/file-service.sock
FILE_STORAGE_ROOT=/data/files
FILE_PUBLIC_ROOT=/data/files/public

MAILPIT_SMTP_HOST=foundjob-mailpit
MAILPIT_SMTP_PORT=1025
EMAIL_FROM=info@foundjob.net

NEXT_PUBLIC_APP_URL=http://localhost:8080
NEXT_PUBLIC_BACKOFFICE_URL=http://localhost:8080/backoffice
