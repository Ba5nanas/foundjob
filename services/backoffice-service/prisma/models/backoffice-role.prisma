model BackofficeRole {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  level       Int
  isSystem    Boolean  @default(false)
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([level])
  @@index([slug])
}
