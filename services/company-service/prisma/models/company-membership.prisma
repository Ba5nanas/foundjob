model CompanyMembership {
  id        String      @id @default(cuid())
  companyId String
  userId    String
  role      CompanyRole
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, userId, role])
  @@index([userId])
}
