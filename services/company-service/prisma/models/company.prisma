model Company {
  id          String   @id @default(cuid())
  name        String
  about       String?
  logoFileId  String?
  coverFileId String?
  ownerUserId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memberships CompanyMembership[]
  employees   CompanyEmployee[]

  @@unique([ownerUserId])
}
