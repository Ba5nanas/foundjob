{
  "name": "@foundjob/main-control",
  "private": true,
  "version": "0.0.0",
  "main": "dist/main.js",
  "scripts": {
    "dev": "bun --watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "bun dist/main.js",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run src",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@foundjob/contracts": "workspace:*",
    "@nestjs/common": "latest",
    "@nestjs/core": "latest",
    "@nestjs/platform-express": "latest",
    "reflect-metadata": "latest",
    "rxjs": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}
